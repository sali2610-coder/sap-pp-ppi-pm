  "records": {
    "sd#0": {
      "doc": "sap_sd_basics.md",
      "module": "SD",
      "heading": "Chapter 1 — Sales Orders",
      "snippet": "A sales order is a customer request to deliver goods or services. Create it with VA01, change with VA02, display with VA03. The header is stored in table VBAK and items in VBAP. The order references a"
    },
    "sd#1": {
      "doc": "sap_sd_basics.md",
      "module": "SD",
      "heading": "Chapter 2 — Delivery",
      "snippet": "The outbound delivery (VL01N) is the logistics document that triggers picking and goods issue. Header table LIKP, items LIPS. Goods issue posts a material movement (type 601) reducing inventory."
    },
    "sd#2": {
      "doc": "sap_sd_basics.md",
      "module": "SD",
      "heading": "Chapter 3 — Billing",
      "snippet": "Billing (VF01) creates the invoice sent to the customer. Header table VBRK, items VBRP. Billing passes the revenue to Financial Accounting, creating an FI document (tables BKPF/BSEG)."
    },
    "mm#0": {
      "doc": "sap_mm_basics.md",
      "module": "MM",
      "heading": "Purchase Order",
      "snippet": "Create with ME21N; header table EKKO, items EKPO."
    },
    "mm#1": {
      "doc": "sap_mm_basics.md",
      "module": "MM",
      "heading": "Goods Receipt",
      "snippet": "Post with MIGO; movement 101 increases stock and writes MSEG."
    },
    "mm#2": {
      "doc": "sap_mm_basics.md",
      "module": "MM",
      "heading": "Invoice Verification",
      "snippet": "Post with MIRO; three-way match against the PO and goods receipt. Creates an FI document (BKPF)."
    },
    "fi#0": {
      "doc": "sap_fi_basics.md",
      "module": "FI",
      "heading": "Documents",
      "snippet": "Every posting creates an FI document; header BKPF, items BSEG."
    },
    "fi#1": {
      "doc": "sap_fi_basics.md",
      "module": "FI",
      "heading": "Integration",
      "snippet": "SD billing (VF01) and MM invoice verification (MIRO) both post FI documents via account determination."
    }
  },
