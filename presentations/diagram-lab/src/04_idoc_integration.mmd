flowchart LR
    subgraph EXT["External Partners"]
        Z["Zetes / Daymax<br/>MES · WMS"]
        EDI["EDI Partner"]
    end
    subgraph MW["Middleware"]
        PIPO["SAP PI/PO<br/>iFlow · mapping"]
        PORT["Port / RFC<br/>WE21 · SM59"]
    end
    subgraph SAP["SAP ECC / S4"]
        subgraph ALE["ALE Layer"]
            PART["Partner Profile<br/>WE20"]
            MODEL["Distribution Model<br/>BD64"]
        end
        subgraph IDOCL["IDoc Processing"]
            IN["Inbound IDoc<br/>ORDERS05 · WE19"]
            OUT["Outbound IDoc<br/>ORDRSP · WE02"]
            FM["Function Module<br/>IDOC_INPUT_*"]
        end
        APP["Application Doc<br/>VBAK · EKKO · AUFK"]
    end

    Z -->|ORDERS| PIPO
    EDI -->|EDIFACT| PIPO
    PIPO --> PORT
    PORT --> PART
    PART --> MODEL
    MODEL --> IN
    IN --> FM
    FM --> APP
    APP --> OUT
    OUT -->|status 03/16| PORT

