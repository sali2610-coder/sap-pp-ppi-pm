{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "deck_spec",
  "type": "object",
  "required": ["meta", "theme_ref", "slides"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["title", "aspect", "language"],
      "properties": {
        "title": {"type": "string"},
        "aspect": {"enum": ["16:9", "4:3"]},
        "language": {"enum": ["en", "he", "bilingual"]},
        "author": {"type": "string"}
      }
    },
    "theme_ref": {"type": "string", "description": "path to theme.json"},
    "slides": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["n", "role", "action_title"],
        "properties": {
          "n": {"type": "integer"},
          "role": {"enum": ["title","motivation","question","method","result","discussion","conclusions","references","section","appendix"]},
          "action_title": {"type": "string", "description": "complete-sentence takeaway"},
          "content": {"type": "array", "items": {"type": "string"}, "description": "body lines, <=~40 words total"},
          "notes": {"type": "string", "description": "speaker notes"},
          "citations": {"type": "array", "items": {"type": "string"}, "description": "evidence-ledger cite_keys"},
          "exhibit": {
            "type": "object",
            "properties": {
              "type": {"enum": ["none","chart","table","diagram","image","quote"]},
              "chart_type": {"enum": ["bar","line","pie","doughnut","area","scatter"]},
              "data": {"type": "array"},
              "rows": {"type": "array"},
              "asset_ref": {"type": "string"},
              "annotation": {"type": "string"},
              "source": {"type": "string"}
            },
            "required": ["type"]
          },
          "layout": {"type": "string"}
        }
      }
    },
    "appendix": {"type": "array"}
  }
}
